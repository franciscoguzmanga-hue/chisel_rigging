}

#BtnShapeColorYellow{
color: rgb(68, 68, 68);
	background-color:rgb(255, 255, 155);
}

#BtnShapeColorRed{
color: rgb(68, 68, 68);
	background-color:rgb(255, 155, 155);
}

#BtnShapeColorGreen{
color: rgb(68, 68, 68);
	background-color: rgb(155, 255, 155);
}

#BtnShapeColorPurple{
color: rgb(68, 68, 68);
	background-color: rgb(200, 122, 200);
}

#LayShapeColorM{
    border-radius: 25px;
}
</string>
